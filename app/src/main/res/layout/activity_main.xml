<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:text="@string/app_name"
            android:textColor="@color/primary_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/bill_amount_label"
            android:textColor="@color/primary_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/billAmountInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/bill_amount_hint"
            android:importantForAutofill="no"
            android:inputType="numberDecimal"
            android:singleLine="true"
            android:textSize="18sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/tip_percent_label"
            android:textColor="@color/primary_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/tipPercentInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/default_tip_percent"
            android:importantForAutofill="no"
            android:inputType="number"
            android:maxLength="2"
            android:singleLine="true"
            android:text="@string/default_tip_percent"
            android:textSize="18sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/people_count_label"
            android:textColor="@color/primary_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/peopleCountInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/default_people_count"
            android:importantForAutofill="no"
            android:inputType="number"
            android:maxLength="2"
            android:singleLine="true"
            android:text="@string/default_people_count"
            android:textSize="18sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/rounding_label"
            android:textColor="@color/primary_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/roundingGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checkedButton="@id/roundNearestButton"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/roundDownButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/round_down"
                android:textSize="16sp" />

            <RadioButton
                android:id="@+id/roundUpButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/round_up"
                android:textSize="16sp" />

            <RadioButton
                android:id="@+id/roundNearestButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/round_nearest"
                android:textSize="16sp" />
        </RadioGroup>

        <Button
            android:id="@+id/calculateButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/calculate"
            android:textAllCaps="false" />

        <TextView
            android:id="@+id/errorView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/error_text"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tipAmountView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/tip_amount_empty"
            android:textColor="@color/primary_text"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/totalAmountView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/total_amount_empty"
            android:textColor="@color/primary_text"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/perPersonAmountView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/per_person_amount_empty"
            android:textColor="@color/primary_text"
            android:textSize="18sp" />
    </LinearLayout>
</ScrollView>
