<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:text="@string/app_name"
            android:textColor="@color/primary_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Сумма счета (до двух знаков после запятой)"
            android:textColor="@color/primary_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/billAmountInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Например: 1200.50"
            android:importantForAutofill="no"
            android:inputType="numberDecimal"
            android:singleLine="true"
            android:textSize="18sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Процент чаевых (целое число 5–30, по умолчанию 15%)"
            android:textColor="@color/primary_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/tipPercentInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="15"
            android:importantForAutofill="no"
            android:inputType="number"
            android:maxLength="2"
            android:singleLine="true"
            android:text="15"
            android:textSize="18sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Количество человек (целое число 1–20, по умолчанию 1)"
            android:textColor="@color/primary_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/peopleCountInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="1"
            android:importantForAutofill="no"
            android:inputType="number"
            android:maxLength="2"
            android:singleLine="true"
            android:text="1"
            android:textSize="18sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Округление суммы чаевых"
            android:textColor="@color/primary_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/roundingGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checkedButton="@id/roundNearestButton"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/roundDownButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="В меньшую сторону"
                android:textSize="16sp" />

            <RadioButton
                android:id="@+id/roundUpButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="В большую сторону"
                android:textSize="16sp" />

            <RadioButton
                android:id="@+id/roundNearestButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="До ближайшего целого"
                android:textSize="16sp" />
        </RadioGroup>

        <Button
            android:id="@+id/calculateButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Рассчитать"
            android:textAllCaps="false" />

        <TextView
            android:id="@+id/errorView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="#B00020"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tipAmountView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Сумма чаевых: —"
            android:textColor="@color/primary_text"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/totalAmountView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Общая сумма: —"
            android:textColor="@color/primary_text"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/perPersonAmountView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Сумма на каждого: —"
            android:textColor="@color/primary_text"
            android:textSize="18sp" />
    </LinearLayout>
</ScrollView>
